@model List<Project5Day.WebUI.Dtos.TeamDtos.ResultTeamDto>

@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="panel">

    <div class="d-flex justify-content-between align-items-center mb-4">

        <div class="panel-title">
            Teams
        </div>

        <a href="/AdminTeam/CreateTeam"
           class="btn btn-success px-4 py-2 rounded-4 fw-bold">

            + Add Team

        </a>

    </div>

    <div class="panel">

        <div class="d-flex justify-content-between align-items-center mb-4">

            <div class="panel-title">
                Teams
            </div>

            <a href="/AdminTeam/CreateTeam"
               class="btn btn-success rounded-4 px-4 fw-bold">

                + Add Team

            </a>

        </div>

        <div class="table-responsive">

            <table style="width:100%;
                      border-collapse:separate;
                      border-spacing:0 14px;">

                <thead>

                    <tr style="color:#64748b;
                           font-size:14px;">

                        <th>#</th>

                        <th>Logo</th>

                        <th>Team Name</th>

                        <th>Actions</th>

                    </tr>

                </thead>

                <tbody>

                    @{
                        int count = 0;
                    }

                    @foreach (var item in Model)
                    {
                        count++;

                        <tr style="background:#0f172a;
                                   border-radius:18px;">

                            <td style="padding:20px;
                                       font-weight:800;
                                       color:#22c55e;">

                                @count

                            </td>

                            <td style="padding:20px;">

                                <img src="@item.LogoUrl"
                                     style="width:52px;
                                            height:52px;
                                            object-fit:contain;
                                            border-radius:50%;
                                            background:#020617;
                                            padding:6px;" />

                            </td>

                            <td style="padding:20px;
                                       color:white;
                                       font-weight:700;
                                       font-size:16px;">

                                @item.TeamName

                            </td>

                            <td style="padding:20px;">

                                <a href="#"
                                   class="btn btn-danger rounded-pill px-4">

                                    Delete

                                </a>

                                <a href="#"
                                   class="btn btn-warning rounded-pill px-4 ms-2">

                                    Update

                                </a>

                            </td>

                        </tr>
                    }

                </tbody>

            </table>

        </div>

    </div>
</div>