<!DOCTYPE html>
<html lang="tr">

<head>

    <meta charset="utf-8" />

    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <title>GoalZone Admin</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
          rel="stylesheet" />

    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap"
          rel="stylesheet">

    <style>

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            background: #020617;
            color: white;
            font-family: 'Inter', sans-serif;
            overflow-x: hidden;
        }

        .admin-layout {
            display: flex;
            min-height: 100vh;
        }

        /* SIDEBAR */

        .sidebar {
            width: 290px;
            background: #081120;
            border-right: 1px solid #162033;
            padding: 30px 24px;
            position: fixed;
            top: 0;
            left: 0;
            bottom: 0;
        }

        .logo {
            font-size: 32px;
            font-weight: 900;
            margin-bottom: 50px;
            color: white;
        }

            .logo span {
                color: #22c55e;
            }

        .menu-title {
            color: #64748b;
            font-size: 12px;
            font-weight: 800;
            letter-spacing: 1px;
            margin-bottom: 16px;
        }

        .menu {
            display: flex;
            flex-direction: column;
            gap: 10px;
        }

            .menu a {
                height: 54px;
                border-radius: 16px;
                display: flex;
                align-items: center;
                gap: 14px;
                padding: 0 18px;
                color: #cbd5e1;
                text-decoration: none;
                transition: .3s;
                font-weight: 700;
            }

                .menu a:hover {
                    background: #0f172a;
                    color: white;
                }

                .menu a.active {
                    background: #22c55e;
                    color: white;
                }

            .menu i {
                font-size: 18px;
            }

        /* MAIN */

        .main {
            margin-left: 290px;
            width: calc(100% - 290px);
            padding: 40px;
        }

        /* TOPBAR */

        .topbar {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 40px;
        }

        .page-title h1 {
            font-size: 42px;
            font-weight: 900;
            margin-bottom: 6px;
        }

        .page-title p {
            color: #94a3b8;
            margin: 0;
        }

        .top-actions {
            display: flex;
            gap: 14px;
        }

        .action-btn {
            width: 48px;
            height: 48px;
            border-radius: 16px;
            background: #0f172a;
            border: 1px solid #1e293b;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #cbd5e1;
            font-size: 18px;
        }

        /* PANEL */

        .panel {
            background: #081120;
            border: 1px solid #162033;
            border-radius: 24px;
            padding: 28px;
        }

        .panel-title {
            font-size: 24px;
            font-weight: 800;
            margin-bottom: 24px;
        }

        table {
            color: white !important;
        }

        /* MOBILE */

        @@media(max-width:850px) {

            .sidebar {
                display: none;
            }

            .main {
                margin-left: 0;
                width: 100%;
                padding: 24px;
            }
        }

    </style>

</head>

<body>

    <div class="admin-layout">

        <!-- SIDEBAR -->

        <aside class="sidebar">

            <div class="logo">

                Goal<span>Zone</span>

            </div>

            <div class="menu-title">
                MANAGEMENT
            </div>

            <div class="menu">

                <a href="/AdminDashboard/Index">

                    <i class="bi bi-grid"></i>

                    Dashboard

                </a>

                <a href="/AdminTeam/Index"
                   class="active">

                    <i class="bi bi-shield"></i>

                    Teams

                </a>

                <a href="#">

                    <i class="bi bi-trophy"></i>

                    Matches

                </a>

                <a href="#">

                    <i class="bi bi-bar-chart"></i>

                    Statistics

                </a>

                <a href="#">

                    <i class="bi bi-people"></i>

                    Players

                </a>

                <a href="#">

                    <i class="bi bi-gear"></i>

                    Settings

                </a>

            </div>

        </aside>

        <!-- MAIN -->

        <main class="main">

            <!-- TOPBAR -->

            <div class="topbar">

                <div class="page-title">

                    <h1>
                        Admin Panel
                    </h1>

                    <p>
                        GoalZone Football Management System
                    </p>

                </div>

                <div class="top-actions">

                    <div class="action-btn">
                        <i class="bi bi-search"></i>
                    </div>

                    <div class="action-btn">
                        <i class="bi bi-bell"></i>
                    </div>

                    <div class="action-btn">
                        <i class="bi bi-person"></i>
                    </div>

                </div>

            </div>

            @RenderBody()

        </main>

    </div>

</body>

</html>